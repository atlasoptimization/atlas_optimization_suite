{
  "id": "local-release",
  "description": "Downloadable static local release profile.",
  "basePath": "./",
  "githubUrl": "https://github.com/your-org/data-science-deck-app",
  "releaseUrl": "https://github.com/your-org/data-science-deck-app/releases",
  "features": {
    "enableLocalSaveLoad": true,
    "enableSessionJsonImportExport": true,
    "enableCustomAssets": true,
    "enableCustomCards": true,
    "enableCustomDomains": true,
    "enableDeveloperPanel": false,
    "enableAskAiContextExport": true,
    "enableTimers": true,
    "enableDeskPngExport": true
  },
  "assets": {
    "includedDomains": ["Source", "Structure", "Chameleon", "Void", "Volition", "Aspect"],
    "includeCustomDomains": true,
    "includePdfs": true,
    "includePreviews": true,
    "includeHandbook": true,
    "includeBackgrounds": true,
    "includeIcons": true,
    "allowPrivateSyncRoots": true
  }
}
